          "body": "{\n  \"success\": true,\n  \"data\": []\n}",
          "_postman_previewlanguage": "json"
        },
        {
          "name": "400 Bad Request - userId inválido",
          "status": "Bad Request",
          "code": 400,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"error\": \"invalid userId: must be a UUID\"\n}",
          "_postman_previewlanguage": "json"
        }
      ]
    }
  ]
