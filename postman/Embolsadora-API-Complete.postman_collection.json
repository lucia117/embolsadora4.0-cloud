        }
      ]
    },
    {
      "name": "User Roles",
      "item": [
        {
          "name": "POST Assign Role",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"tenantId\": \"{{tenantId}}\",\n  \"roleId\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/user-roles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "user-roles"]
            }
          }
        },
        {
          "name": "GET List Assignments",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/v1/user-roles?tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "user-roles"],
              "query": [{"key": "tenantId", "value": "{{tenantId}}"}]
            }
          }
        },
        {
          "name": "PUT Update Role",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"roleId\": \"operario\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/user-roles/{{utrId}}",
