{
  "info": {
    "_postman_id": "user-management-api-collection",
    "name": "User Management API",
    "description": "Multi-tenant User Management API - CRUD operations for users within a tenant\n\n**Authentication**: All requests require `Authorization: Bearer <jwt_token>` header\n**Tenant Isolation**: All requests require `X-Tenant-ID: <tenant_uuid>` header\n**Base URL**: {{base_url}}/api/v1",
