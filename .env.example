# Database
DATABASE_URL=postgres://embolsadora_user:embolsadora_password@localhost:5432/embolsadora_dev?sslmode=disable

# Redis
REDIS_URL=redis://:embolsadora_redis_pass@localhost:6379/0

# Application
PORT=8080
APP_ENV=development

# Supabase — reemplazar con tus valores reales
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_SERVICE_ROLE_KEY=<tu-service-role-key>
SUPABASE_ANON_KEY=<tu-anon-key>

# Frontend URL (para links en emails de invitación)
APP_BASE_URL=http://localhost:3000

# Rate limiting
INVITATION_RATE_LIMIT_PER_HOUR=20

# MongoDB (opcional — el servidor arranca sin esto, con WARN en el log)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=embolsadora_dev
# Para tests de integración de repositorios MongoDB (go test ./internal/repo/mongo/...)
# MONGO_TEST_URI=mongodb://localhost:27017
