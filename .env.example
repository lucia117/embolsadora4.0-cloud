# Ambiente: local | beta | production
# En local se carga desde .env.local; en Koyeb/PaaS se inyecta directamente.
APP_ENV=local

# ── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=postgres://<usuario>:<password>@<host>:5432/<dbname>?sslmode=disable

# ── Redis (opcional — rate limiting falla abierto si no está disponible) ─────
REDIS_URL=redis://:<password>@<host>:6379/0

# ── HTTP ─────────────────────────────────────────────────────────────────────
PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_JWKS_URL=https://<project-id>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://<project-id>.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_ANON_KEY=<anon-key>

# ── Frontend (para links en emails) ──────────────────────────────────────────
APP_BASE_URL=http://localhost:3000

# ── Rate limiting ─────────────────────────────────────────────────────────────
INVITATION_RATE_LIMIT_PER_HOUR=20

# ── Observabilidad ────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
